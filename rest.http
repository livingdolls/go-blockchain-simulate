### Create New Admin
POST http://localhost:3010/admin/admins
Content-Type: application/json
Cookie: admin_token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjozLCJ1c2VybmFtZSI6ImFkbWluIiwicm9sZSI6ImFkbWluIiwiZXhwIjoxNzc1MTkxMjU3LCJpYXQiOjE3NzUxMDQ4NTd9.wve9V2BUauPdQk9tRUgSR59bO5FLzDHZyejgifRmUvo"

{
  "user_id": 4,
  "role": "moderator",
  "permissions": ["read_dashboard", "view_activity_logs", "read_users"]
}

### Update Admin Role
PUT http://localhost:3010/admin/admins/2/role
Content-Type: application/json
Cookie: admin_token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjozLCJ1c2VybmFtZSI6ImFkbWluIiwicm9sZSI6ImFkbWluIiwiZXhwIjoxNzc1MTkxMjU3LCJpYXQiOjE3NzUxMDQ4NTd9.wve9V2BUauPdQk9tRUgSR59bO5FLzDHZyejgifRmUvo"

{
  "role": "support",
  "permissions": ["read_users", "view_activity_logs"]
}

